{
  "compilerOptions": {
    "target": "ES2020",
    "module": "ES2020",
    "moduleResolution": "node",

    "rootDir": "./src",
    "outDir": "./dist",

    "strict": true,

    "lib": ["DOM", "ES2020"],

    "sourceMap": false,
    "declaration": false,
    "declarationMap": false,

    "skipLibCheck": true
  },
  "include": ["src/**/*.ts"]
}